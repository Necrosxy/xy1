.mistakes-screen {
  padding-top: 24rpx;
}

.top-bar {
  display: flex;
  min-height: 108rpx;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.top-bar__title {
  flex: 1;
  min-width: 0;
  margin: 0 24rpx;
  text-align: center;
}

.top-bar__heading {
  display: block;
  overflow: hidden;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-bar__meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 700;
}

.start-button {
  margin-top: 0;
}

.mistake-list {
  display: block;
  margin-top: 28rpx;
}

.mistake-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.pill {
  display: inline-flex;
  min-height: 52rpx;
  align-items: center;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #1f5be3;
  background: #eaf1ff;
  font-size: 26rpx;
  font-weight: 800;
}

.mistake-card__stem {
  display: block;
  margin-top: 22rpx;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.52;
}

.empty-state {
  display: flex;
  min-height: 360rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  text-align: center;
}

.empty-state__title {
  font-size: 38rpx;
  font-weight: 900;
}

.empty-state__text {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.5;
}
