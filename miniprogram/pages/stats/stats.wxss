.stats-screen {
  padding-top: 24rpx;
}

.top-bar {
  display: flex;
  min-height: 108rpx;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.top-bar__title {
  flex: 1;
  min-width: 0;
  margin: 0 24rpx;
  text-align: center;
}

.top-bar__heading {
  display: block;
  overflow: hidden;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-bar__meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 700;
}

.metric-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.metric-card {
  width: 325rpx;
  min-height: 220rpx;
  margin-bottom: 28rpx;
  padding: 34rpx;
  flex: 0 0 325rpx;
}

.metric-card__label {
  display: block;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 800;
}

.metric-card__value {
  display: block;
  margin-top: 26rpx;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1;
}

.progress-list {
  display: block;
}

.progress-card {
  display: flex;
  min-height: 160rpx;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 30rpx 36rpx;
}

.progress-card__icon {
  display: flex;
  width: 84rpx;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  border-radius: 28rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.progress-card__title {
  display: block;
  margin-left: 30rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.progress-card__meta {
  display: block;
  margin-left: 30rpx;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 700;
}
